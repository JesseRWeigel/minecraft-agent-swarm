async function collectBamboo(bot) {
  const { goals } = require('mineflayer-pathfinder');
  const mcData = require('minecraft-data');
  const bambooId = mcData.blocksByName.bamboo.id;
  const bambooPlants = await exploreUntil(bot, new Vec3(1, 0, 1), 60, () => {
    const blocks = bot.findBlocks({ matching: bambooId, maxDistance: 32, count: 10 });
    return blocks.length >= 10 ? blocks : null;
  });
  if (!bambooPlants) throw new Error("Cannot find bamboo nearby");
  for (const pos of bambooPlants) {
    const block = bot.blockAt(pos);
    if (block) await bot.dig(block);
  }
  for (const pos of bambooPlants) {
    await bot.pathfinder.goto(new goals.GoalNear(pos.x, pos.y, pos.z, 1));
  }
  bot.chat("Collected 10 bamboo.");
}